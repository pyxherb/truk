import types;

public class EventHandlerSet {
	/// Pre-event override function. Unspecified means do not to override.
	pre?: fn () -> int,
	/// On-event override function. Unspecified means do not to override.
	on?: fn () -> int,
	/// Post-event override function. Unspecified means do not to override.
	post?: fn () -> int
}

public class EventHookSet {
	/// Pre-event hook function.
	pre: fn? () -> int,
	/// Post-event hook function.
	post: fn? () -> int
}
